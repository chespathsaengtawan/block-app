<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:BlockApp.App.Views"
             x:Class="BlockApp.App.MainPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="*,Auto">
        
        <!-- Content Area -->
        <Grid Grid.Row="0">
            <views:HomeView    x:Name="HomeViewEl"    IsVisible="True" />
            <views:SearchView  x:Name="SearchViewEl"  IsVisible="False"/>
            <views:HistoryView x:Name="HistoryViewEl" IsVisible="False"/>
            <views:ProfileView x:Name="ProfileViewEl" IsVisible="False"/>
        </Grid>

        <!-- Bottom Navigation Bar -->
        <Border Grid.Row="1"
                BackgroundColor="White"
                Padding="0,8,0,8"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,-2" Radius="12" Opacity="0.07"/>
            </Border.Shadow>

            <Grid ColumnDefinitions="*,*,84,*,*" HeightRequest="72">

                <!-- Tab 1 -->
                <VerticalStackLayout Grid.Column="0"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab1Tapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border x:Name="Tab1Pill" BackgroundColor="#EDE9FF"
                            Padding="10,5" HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label x:Name="Tab1Icon" Text="&#x1F3E0;" FontSize="18" TextColor="#7C3AED"
                               HorizontalOptions="Center"/>
                    </Border>
                    <Label x:Name="Tab1Lbl" Text="&#x0E2B;&#x0E19;&#x0E49;&#x0E32;&#x0E2B;&#x0E25;&#x0E31;&#x0E01;" FontSize="10"
                           TextColor="#7C3AED" FontAttributes="Bold" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Tab 2 -->
                <VerticalStackLayout 
                    Grid.Column="1"
                    HorizontalOptions="Center" 
                    VerticalOptions="Center"
                    Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab2Tapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border 
                        x:Name="Tab2Pill" 
                        BackgroundColor="Transparent"     
                        Padding="10,5" 
                        HorizontalOptions="Center" 
                        StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label 
                            x:Name="Tab2Icon" 
                            Text="&#x1F50D;" 
                            FontSize="18" 
                            TextColor="#9CA3AF" 
                            HorizontalOptions="Center"/>
                    </Border>
                    <Label 
                        x:Name="Tab2Lbl" 
                        Text="&#x0E04;&#x0E49;&#x0E19;&#x0E2B;&#x0E32;" 
                        FontSize="10" 
                        TextColor="#9CA3AF" 
                        HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Center FAB -->
                <Border Grid.Column="2"
                        BackgroundColor="#7C3AED"
                        WidthRequest="54" HeightRequest="54"
                        HorizontalOptions="Center" VerticalOptions="Center"
                        StrokeThickness="0" Margin="0,-12,0,0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="27"/>
                    </Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="#7C3AED" Offset="0,4" Radius="14" Opacity="0.45"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnFabTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="+" FontSize="28" FontAttributes="Bold" TextColor="White"
                           HorizontalOptions="Center" VerticalOptions="Center" Margin="0,-2,0,0"/>
                </Border>

                <!-- Tab 3 -->
                <VerticalStackLayout Grid.Column="3"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab3Tapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border x:Name="Tab3Pill" BackgroundColor="Transparent"
                            Padding="10,5" HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label x:Name="Tab3Icon" Text="&#x1F4CB;" FontSize="18" TextColor="#9CA3AF"
                               HorizontalOptions="Center"/>
                    </Border>
                    <Label x:Name="Tab3Lbl" Text="&#x0E1B;&#x0E23;&#x0E30;&#x0E27;&#x0E31;&#x0E15;&#x0E34;" FontSize="10"
                           TextColor="#9CA3AF" HorizontalOptions="Center"/>
                </VerticalStackLayout>

                <!-- Tab 4 -->
                <VerticalStackLayout Grid.Column="4"
                                     HorizontalOptions="Center" VerticalOptions="Center"
                                     Spacing="2">
                    <VerticalStackLayout.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnTab4Tapped"/>
                    </VerticalStackLayout.GestureRecognizers>
                    <Border x:Name="Tab4Pill" BackgroundColor="Transparent"
                            Padding="10,5" HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="15"/>
                        </Border.StrokeShape>
                        <Label x:Name="Tab4Icon" Text="&#x1F464;" FontSize="18" TextColor="#9CA3AF"
                               HorizontalOptions="Center"/>
                    </Border>
                    <Label x:Name="Tab4Lbl" Text="&#x0E42;&#x0E1B;&#x0E23;&#x0E44;&#x0E1F;&#x0E25;&#x0E4C;" FontSize="10"
                           TextColor="#9CA3AF" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Grid>
        </Border>
    </Grid>

</ContentPage>
