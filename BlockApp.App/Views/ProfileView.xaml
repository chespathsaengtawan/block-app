<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BlockApp.App.Views.ProfileView">

    <Grid RowDefinitions="Auto,*,Auto" BackgroundColor="#F9FAFB">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="White" Padding="20,30,20,16" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="โปรไฟล์" FontSize="22" FontAttributes="Bold" TextColor="#111827"/>
                </VerticalStackLayout>
                <Border Grid.Column="2" BackgroundColor="#F3F0FF" WidthRequest="160" HeightRequest="42"
                        HorizontalOptions="End" VerticalOptions="Center" StrokeThickness="0">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="21"/>
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label x:Name="TotalPoint" 
                               Text="คงเหลือ 0 พอยต์" 
                               FontSize="14" 
                               FontAttributes="Bold"
                               TextColor="#7C3AED"
                               VerticalOptions="Center"/>
                        <Border BackgroundColor="#7C3AED" 
                                Padding="8,4"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="8"/>
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBuyPointsTapped"/>
                            </Border.GestureRecognizers>
                            <Label Text="+ ซื้อ" 
                                   FontSize="12" 
                                   FontAttributes="Bold"
                                   TextColor="White"
                                   VerticalOptions="Center"/>
                        </Border>
                    </HorizontalStackLayout>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,20" Spacing="16">

                <!-- Avatar + Info -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="10" Margin="0,8,0,20">
                    <Grid WidthRequest="130" HeightRequest="130">
                        <Border BackgroundColor="#F9FAFB" WidthRequest="120" HeightRequest="120"
                            HorizontalOptions="Center" ZIndex="0" StrokeThickness="0">
                        <Border.Shadow>
                            <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.06"/>
                        </Border.Shadow>
                        <Border.StrokeShape><RoundRectangle CornerRadius="60"/></Border.StrokeShape>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnAvatarTapped"/>
                        </Border.GestureRecognizers>
                        <Grid>
                            <Image x:Name="AvatarImage"
                                   Aspect="AspectFill"
                                   IsVisible="False">
                                <Image.Clip>
                                    <RoundRectangleGeometry CornerRadius="60" Rect="0,0,120,120"/>
                                </Image.Clip>
                            </Image>
                            <Label x:Name="AvatarPlaceholder"
                                   Text="&#x1F464;" FontSize="36"
                                   HorizontalOptions="Center" VerticalOptions="Center"/>

                        </Grid> 
                    </Border>
                    <Border BackgroundColor="#7C3AED" 
                            WidthRequest="32" HeightRequest="32"
                            HorizontalOptions="End" VerticalOptions="End"
                            Margin="0,0,4,4"
                            StrokeThickness="2" Stroke="White"
                            ZIndex="10">
                        <Border.StrokeShape><RoundRectangle CornerRadius="16"/></Border.StrokeShape>
                        <Label Text="&#x1F4F7;" FontSize="14"
                               HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>                   
                    </Grid>
                    <Label x:Name="PhoneLabel"
                           Text="กำลังโหลด..."
                           FontSize="18" FontAttributes="Bold"
                           TextColor="#111827" HorizontalOptions="Center"/>
                    <Border BackgroundColor="#EDE9FF" Padding="14,5"
                            HorizontalOptions="Center" StrokeThickness="0">
                        <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                        <Label Text="ผู้ใช้งาน" FontSize="12" TextColor="#7C3AED"/>
                    </Border>
                </VerticalStackLayout>

                <!-- Settings Card -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <VerticalStackLayout>

                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border BackgroundColor="#F3F0FF" WidthRequest="36" HeightRequest="36"
                                    VerticalOptions="Center" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Label Text="&#x1F514;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="การแจ้งเตือน" FontSize="15"
                                   TextColor="#111827" VerticalOptions="Center" Margin="12,0,0,0"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#9CA3AF" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3F4F6" Margin="16,0"/>

                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border BackgroundColor="#F3F0FF" WidthRequest="36" HeightRequest="36"
                                    VerticalOptions="Center" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Label Text="&#x1F512;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="ความเป็นส่วนตัว" FontSize="15"
                                   TextColor="#111827" VerticalOptions="Center" Margin="12,0,0,0"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#9CA3AF" VerticalOptions="Center"/>
                        </Grid>

                        <BoxView HeightRequest="1" Color="#F3F4F6" Margin="16,0"/>

                        <Grid Padding="16,14" ColumnDefinitions="Auto,*,Auto">
                            <Border BackgroundColor="#F3F0FF" WidthRequest="36" HeightRequest="36"
                                    VerticalOptions="Center" StrokeThickness="0">
                                <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                                <Label Text="&#x2753;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                            </Border>
                            <Label Grid.Column="1" Text="ช่วยเหลือ" FontSize="15"
                                   TextColor="#111827" VerticalOptions="Center" Margin="12,0,0,0"/>
                            <Label Grid.Column="2" Text="›" FontSize="20"
                                   TextColor="#9CA3AF" VerticalOptions="Center"/>
                        </Grid>

                    </VerticalStackLayout>
                </Border>

                <!-- Logout -->
                <Border BackgroundColor="White" StrokeThickness="0" Padding="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                    <Border.Shadow>
                        <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
                    </Border.Shadow>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                    </Border.GestureRecognizers>
                    <Grid Padding="16,14" ColumnDefinitions="Auto,*">
                        <Border BackgroundColor="#FEE2E2" WidthRequest="36" HeightRequest="36"
                                VerticalOptions="Center" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                            <Label Text="&#x1F6AA;" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center"/>
                        </Border>
                        <Label Grid.Column="1" Text="ออกจากระบบ" FontSize="15"
                               TextColor="#EF4444" VerticalOptions="Center"
                               Margin="12,0,0,0" FontAttributes="Bold"/>
                    </Grid>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!-- Version App -->
        <Border Grid.Row="2"
                Padding="16,12,16,16"
                StrokeThickness="0"
                BackgroundColor="#F9FAFB">
            <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                <Label Text="เวอร์ชัน" 
                       TextColor="#6B7280" 
                       FontSize="11"
                       FontAttributes="Bold"
                       HorizontalOptions="Center"/>

                <HorizontalStackLayout Spacing="16" HorizontalOptions="Center">
                    <Label x:Name="AppLabelVersion"
                           Text="แอป: 1.0.0" 
                           TextColor="#9CA3AF" 
                           FontSize="11"
                           HorizontalOptions="Center"/>

                    <BoxView WidthRequest="1" 
                             HeightRequest="12" 
                             Color="#D1D5DB"
                             VerticalOptions="Center"/>

                    <Label x:Name="ApiLabelVersion"
                           Text="API: 1.0.0" 
                           TextColor="#9CA3AF" 
                           FontSize="11"
                           HorizontalOptions="Center"/>
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
