<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:BlockApp.App.Models;assembly=BlockApp.App"
             x:Class="BlockApp.App.Views.HistoryView">

    <Grid RowDefinitions="Auto,*" BackgroundColor="#F9FAFB">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="White" Padding="20,30,20,16" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="ประวัติ" FontSize="22" FontAttributes="Bold" TextColor="#111827"/>
                    <Label x:Name="SubtitleLabel" Text="ประวัติการใช้งานทั้งหมด" FontSize="13" TextColor="#6B7280"/>
                </VerticalStackLayout>
                <!-- Clear button -->
                <Border Grid.Column="1" BackgroundColor="#FEF2F2" Padding="10,6"
                        HorizontalOptions="End" VerticalOptions="Center" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnClearHistoryTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="ล้างประวัติ" FontSize="12" FontAttributes="Bold" TextColor="#DC2626"/>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">

            <!-- Loading -->
            <ActivityIndicator x:Name="LoadingIndicator"
                               IsRunning="True" IsVisible="True"
                               Color="#7C3AED"
                               VerticalOptions="Center" HorizontalOptions="Center"/>

            <!-- Empty state -->
            <VerticalStackLayout x:Name="EmptyState" IsVisible="False"
                                 HorizontalOptions="Center" Spacing="14" Margin="0,60,0,0">
                <Label Text="📋" FontSize="60" HorizontalOptions="Center"/>
                <Label Text="ยังไม่มีประวัติ"
                       FontSize="17" FontAttributes="Bold"
                       TextColor="#374151" HorizontalOptions="Center"/>
                <Label Text="ประวัติการใช้งานจะแสดงที่นี่"
                       FontSize="13" TextColor="#9CA3AF"
                       HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
            </VerticalStackLayout>

            <!-- History list -->
            <CollectionView x:Name="HistoryCollection" IsVisible="False" Margin="16,12,16,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:HistoryEntry">
                        <Border Margin="0,0,0,8" Padding="14,12" BackgroundColor="White" StrokeThickness="0">
                            <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="Black" Offset="0,1" Radius="6" Opacity="0.04"/>
                            </Border.Shadow>
                            <Grid ColumnDefinitions="Auto,*">
                                <!-- Color dot -->
                                <BoxView x:Name="ActionDot"
                                         Grid.Column="0"
                                         WidthRequest="10" HeightRequest="10"
                                         CornerRadius="5"
                                         VerticalOptions="Start"
                                         Margin="0,4,12,0"
                                         BackgroundColor="#7C3AED"/>
                                <!-- Content -->
                                <VerticalStackLayout Grid.Column="1" Spacing="2">
                                    <Label Text="{Binding Action, Converter={StaticResource HistoryActionLabelConverter}}"
                                           FontSize="14" FontAttributes="Bold" TextColor="#111827"/>
                                    <Label Text="{Binding Target}"
                                           IsVisible="{Binding Target, Converter={StaticResource NullToBoolConverter}}"
                                           FontSize="13" TextColor="#374151"/>
                                    <Label Text="{Binding BankName}"
                                           IsVisible="{Binding BankName, Converter={StaticResource NullToBoolConverter}}"
                                           FontSize="12" TextColor="#6B7280"/>
                                    <Label Text="{Binding Note}"
                                           IsVisible="{Binding Note, Converter={StaticResource NullToBoolConverter}}"
                                           FontSize="12" TextColor="#9CA3AF"
                                           LineBreakMode="TailTruncation"/>
                                    <Label Text="{Binding OccurredAt, StringFormat='{0:dd/MM/yyyy HH:mm}'}"
                                           FontSize="11" TextColor="#9CA3AF"/>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </Grid>
    </Grid>
</ContentView>
