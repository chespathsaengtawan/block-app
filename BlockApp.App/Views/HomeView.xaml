<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"    
             x:Class="BlockApp.App.Views.HomeView">
    <Grid RowDefinitions="Auto,*" BackgroundColor="#F9FAFB">
        
        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="White" Padding="20,30,20,16" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="เบอร์ที่บล็อก" FontSize="22" FontAttributes="Bold" TextColor="#111827"/>
                    <Label Text="รายการเบอร์โทรที่คุณบล็อกไว้" FontSize="13" TextColor="#6B7280"/>
                </VerticalStackLayout>
                <Border Grid.Column="1" BackgroundColor="#F3F0FF" WidthRequest="42" HeightRequest="42"
                        HorizontalOptions="End" VerticalOptions="Center" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="21"/></Border.StrokeShape>
                    <Label Text="&#x1F6E1;&#xFE0F;" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20,16" Spacing="12">
                <!-- Empty state -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="14" Margin="0,60,0,0">
                    <Label Text="&#x1F6AB;" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="ยังไม่มีเบอร์ที่บล็อก"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="#374151" HorizontalOptions="Center"/>
                    <Label Text="แตะปุ่ม + เพื่อเพิ่มเบอร์ที่ต้องการบล็อก"
                           FontSize="13" TextColor="#9CA3AF"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentView>
