<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BlockApp.App.Views.SearchView">

    <Grid RowDefinitions="Auto,Auto,*" BackgroundColor="#F9FAFB">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="White" Padding="20,30,20,16" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="ค้นหาเบอร์" FontSize="22" FontAttributes="Bold" TextColor="#111827"/>
                    <Label Text="ตรวจสอบเบอร์ที่ผู้ใช้อื่นรายงาน" FontSize="13" TextColor="#6B7280"/>
                </VerticalStackLayout>
                <Border Grid.Column="1" BackgroundColor="#F3F0FF" WidthRequest="42" HeightRequest="42"
                        HorizontalOptions="End" VerticalOptions="Center" StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="21"/></Border.StrokeShape>
                    <Label Text="&#x1F50E;" FontSize="18" HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>
            </Grid>
        </Border>

        <!-- Search Bar -->
        <Border Grid.Row="1" BackgroundColor="White" Padding="16,12" StrokeThickness="0">
            <Border Stroke="#E5E7EB" StrokeThickness="1.5" BackgroundColor="#F9FAFB" Padding="12,0"
                    HeightRequest="48">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <Grid ColumnDefinitions="Auto,*">
                    <Label Text="&#x1F50E;" FontSize="14" VerticalOptions="Center"
                           TextColor="#9CA3AF" Margin="0,0,6,0"/>
                    <Entry Grid.Column="1"
                           x:Name="SearchEntry"
                           Placeholder="ค้นหาเบอร์โทรศัพท์..."
                           PlaceholderColor="#9CA3AF"
                           TextColor="#111827"
                           FontSize="15"
                           BackgroundColor="Transparent"
                           Keyboard="Telephone"
                           VerticalOptions="Center"
                           TextChanged="OnSearchTextChanged"/>
                </Grid>
            </Border>
        </Border>

        <!-- Results -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="20,8" Spacing="12" x:Name="ResultsContainer">
                <!-- Empty state -->
                <VerticalStackLayout HorizontalOptions="Center" Spacing="14" Margin="0,50,0,0">
                    <Label Text="&#x1F50E;" FontSize="60" HorizontalOptions="Center"/>
                    <Label Text="พิมพ์เบอร์โทรเพื่อค้นหา"
                           FontSize="17" FontAttributes="Bold"
                           TextColor="#374151" HorizontalOptions="Center"/>
                    <Label Text="ระบบจะแสดงข้อมูลจากรายงานของผู้ใช้งาน"
                           FontSize="13" TextColor="#9CA3AF"
                           HorizontalOptions="Center" HorizontalTextAlignment="Center"/>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>

    </Grid>
</ContentView>
