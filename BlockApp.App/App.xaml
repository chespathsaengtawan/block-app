<?xml version = "1.0" encoding = "UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:BlockApp.App"
             xmlns:controls="clr-namespace:BlockApp.App.Controls"
             x:Class="BlockApp.App.App">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/Styles/Colors.xaml" />
                <ResourceDictionary Source="Resources/Styles/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>
            
            <!-- Converters -->
            <controls:IsNotZeroConverter x:Key="IsNotZeroConverter" />
            <controls:NullToBoolConverter x:Key="NullToBoolConverter" />
            <controls:HistoryActionLabelConverter x:Key="HistoryActionLabelConverter" />
            <controls:BlockReasonLabelConverter x:Key="BlockReasonLabelConverter" />
            <controls:BlockReasonChipsConverter x:Key="BlockReasonChipsConverter" />
            <controls:BlockReasonFlagConverter x:Key="BlockReasonFlagConverter" />
            <controls:BlockEntryTypeIconConverter x:Key="BlockEntryTypeIconConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>

