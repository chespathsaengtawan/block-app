<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BlockApp.App.Pages.BuyPointsPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <Border Grid.Row="0" BackgroundColor="White" Padding="20,50,20,16" StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,2" Radius="8" Opacity="0.05"/>
            </Border.Shadow>
            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                    <Label Text="ซื้อพอยต์" FontSize="20" FontAttributes="Bold" TextColor="#111827"/>
                    <Label x:Name="BalanceLabel" Text="ยอดคงเหลือ : 0 พอยต์" FontSize="13" TextColor="#6B7280"/>
                </VerticalStackLayout>
                
                <Border Grid.Column="1"
                        BackgroundColor="#F3F4F6" 
                        WidthRequest="70" HeightRequest="38"
                        VerticalOptions="Center" 
                        HorizontalOptions="End"
                        StrokeThickness="0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="19"/></Border.StrokeShape>
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBackTapped"/>
                    </Border.GestureRecognizers>
                    <Label Text="ยกเลิก" FontSize="14" TextColor="#374151"
                           HorizontalOptions="Center" VerticalOptions="Center"/>
                </Border>               
            </Grid>
        </Border>

        <!-- Content -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="20" Spacing="16">
                <!-- Packages -->
                <Label Text="แพ็กเกจ" FontSize="16" FontAttributes="Bold" TextColor="#111827" Margin="0,8,0,8"/>
                <CollectionView x:Name="PackagesCollection" SelectionMode="None">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" StrokeThickness="1" Stroke="#E5E7EB" 
                                    Padding="16" Margin="0,0,0,12">
                                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                                <Border.GestureRecognizers>
                                    <TapGestureRecognizer Tapped="OnPackageTapped" CommandParameter="{Binding .}"/>
                                </Border.GestureRecognizers>
                                <Grid ColumnDefinitions="*,Auto">
                                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                                        <Label Text="{Binding Points, StringFormat='{0:N0} '}" 
                                               FontSize="18" FontAttributes="Bold" TextColor="#111827"/>
                                        <Label Text="{Binding PriceTHB, StringFormat='{0:N0}'}" 
                                               FontSize="14" TextColor="#6B7280"/>
                                        <Label Text="{Binding BonusPoints, StringFormat='+ ฿ {0} '}" 
                                               FontSize="12" TextColor="#10B981" FontAttributes="Bold"
                                               IsVisible="{Binding BonusPoints, Converter={StaticResource IsNotZeroConverter}}"/>
                                    </VerticalStackLayout>
                                    <Border Grid.Column="1" BackgroundColor="#7C3AED" 
                                            Padding="20,12" StrokeThickness="0" VerticalOptions="Center">
                                        <Border.StrokeShape><RoundRectangle CornerRadius="8"/></Border.StrokeShape>
                                        <Label Text="ซื้อ" TextColor="White" FontSize="14" FontAttributes="Bold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
                <!-- Info -->
                <Border BackgroundColor="#F0FDF4" Stroke="#BBF7D0" StrokeThickness="1" Padding="14,12" Margin="0,16,0,0">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <Label Text="ข้อมูลการชำระเงิน" FontSize="14" FontAttributes="Bold" TextColor="#166534"/>
                        <Label Text="สแกน QR Code ผ่าน Mobile Banking" FontSize="12" TextColor="#166534"/>
                        <Label Text="หรือใช้ PromptPay" FontSize="12" TextColor="#166534"/>
                        <Label Text="การทำรายการอาจใช้เวลา 1-2 นาที" FontSize="12" TextColor="#166534"/>
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
